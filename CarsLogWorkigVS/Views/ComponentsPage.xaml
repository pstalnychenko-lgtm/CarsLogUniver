<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.ComponentsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*">
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="15,25,15,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Компоненти" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center" />
                <Button Grid.Column="2" Text="+" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="26" WidthRequest="44" Clicked="OnAddClicked" />
            </Grid>
        </Frame>

        <CollectionView Grid.Row="1" x:Name="ComponentsCollection"
                        EmptyView="Компонентів немає. Додайте перший."
                        Margin="16,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White" CornerRadius="14" Margin="0,4"
                           HasShadow="False" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding PartName}" FontSize="15"
                                       FontAttributes="Bold" TextColor="#1D1D1F" />
                                <Label Text="{Binding InstallationDate, StringFormat='Встановлено: {0:dd.MM.yyyy}'}"
                                       FontSize="12" TextColor="#6E6E73" />
                                <Label Text="{Binding InstallationMileage, StringFormat='Пробіг при встановленні: {0} км'}"
                                       FontSize="12" TextColor="#6E6E73" />
                            </VerticalStackLayout>
                            <Frame Grid.Column="1" CornerRadius="8" Padding="8,4"
                                   HasShadow="False" VerticalOptions="Center">
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame" Binding="{Binding IsExpired}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#FFF1F0" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding IsExpired}" Value="False">
                                        <Setter Property="BackgroundColor" Value="#F0FFF4" />
                                    </DataTrigger>
                                </Frame.Triggers>
                                <Label FontSize="12" FontAttributes="Bold">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsExpired}" Value="True">
                                            <Setter Property="Text" Value="Замінити" />
                                            <Setter Property="TextColor" Value="#FF3B30" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsExpired}" Value="False">
                                            <Setter Property="Text" Value="OK" />
                                            <Setter Property="TextColor" Value="#34C759" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Frame>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
