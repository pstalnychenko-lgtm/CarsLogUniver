<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.AddDriverPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*">
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="15,25,15,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Новий водій" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center" />
                <Button Grid.Column="2" Text="Зберегти" BackgroundColor="Transparent"
                        TextColor="#0071E3" FontSize="15" Clicked="OnSaveClicked" />
            </Grid>
        </Frame>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="16">

                <Label Text="Ім'я *" FontSize="13" TextColor="#6E6E73" Margin="4,8,0,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="FirstNameEntry" Placeholder="Ім'я"
                           FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Прізвище *" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="LastNameEntry" Placeholder="Прізвище"
                           FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Телефон *" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="PhoneEntry" Placeholder="+380..." Keyboard="Telephone"
                           FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Номер посвідчення водія *" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="LicenseEntry" Placeholder="DRV-1234567"
                           FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Орган видачі посвідчення *" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="IssuedByEntry" Placeholder="ТСЦ №..."
                           FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Дата закінчення посвідчення *" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="8,0">
                    <DatePicker x:Name="ExpiryDatePicker" Format="dd.MM.yyyy" FontSize="16"
                                TextColor="#1D1D1F" />
                </Frame>

                <Label Text="Група крові" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="8,0">
                    <Picker x:Name="BloodTypePicker" FontSize="16" TextColor="#1D1D1F">
                        <Picker.Items>
                            <x:String>A+</x:String>
                            <x:String>A-</x:String>
                            <x:String>B+</x:String>
                            <x:String>B-</x:String>
                            <x:String>AB+</x:String>
                            <x:String>AB-</x:String>
                            <x:String>O+</x:String>
                            <x:String>O-</x:String>
                        </Picker.Items>
                    </Picker>
                </Frame>

                <Grid ColumnDefinitions="*,Auto" Margin="4,4">
                    <Label Grid.Column="0" Text="Наявність медичної довідки"
                           FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                    <Switch x:Name="MedCertSwitch" Grid.Column="1" IsToggled="True" />
                </Grid>

                <Label x:Name="ErrorLabel" TextColor="#FF3B30" FontSize="13"
                       HorizontalOptions="Center" IsVisible="False" />

                <Button Text="Додати водія" BackgroundColor="#0071E3" TextColor="White"
                        FontAttributes="Bold" FontSize="17" CornerRadius="12"
                        HeightRequest="52" Margin="0,8,0,24" Clicked="OnSaveClicked" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
