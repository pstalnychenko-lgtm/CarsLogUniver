<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.ExpensesPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,Auto,*">
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="15,25,15,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Витрати" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center" />
                <Button Grid.Column="2" Text="+" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="26" WidthRequest="44" Clicked="OnAddClicked" />
            </Grid>
        </Frame>

        <Frame Grid.Row="1" BackgroundColor="#EBF4FF" CornerRadius="0" HasShadow="False" Padding="16,12">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Загальні витрати:" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                <Label x:Name="TotalLabel" Text="0.00 грн" FontSize="18" FontAttributes="Bold"
                       TextColor="#0071E3" Grid.Column="1" VerticalOptions="Center" />
            </Grid>
        </Frame>

        <CollectionView Grid.Row="2" x:Name="ExpensesCollection"
                        EmptyView="Витрат немає. Додайте першу витрату."
                        Margin="16,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White" CornerRadius="14" Margin="0,4"
                           HasShadow="False" Padding="16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Frame Grid.Column="0" BackgroundColor="#F0F5FF" CornerRadius="10"
                                   Padding="10,6" HasShadow="False" VerticalOptions="Center">
                                <Label Text="{Binding Category}" FontSize="12" TextColor="#0071E3"
                                       FontAttributes="Bold" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="12,0,0,0">
                                <Label Text="{Binding Description}" FontSize="14"
                                       TextColor="#1D1D1F" MaxLines="1" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding ExpenseDate, StringFormat='{0:dd.MM.yyyy}'}"
                                       FontSize="12" TextColor="#6E6E73" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="{Binding Amount, StringFormat='{0:N2} грн'}"
                                   FontSize="15" FontAttributes="Bold" TextColor="#FF3B30"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
