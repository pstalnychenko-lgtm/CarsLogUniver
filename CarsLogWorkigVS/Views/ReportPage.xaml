<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.ReportPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*">
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="15,25,15,15">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Звіт" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center"
                       Margin="-44,0,0,0" />
            </Grid>
        </Frame>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="16">

                <Label Text="Тижневий звіт" FontSize="17" FontAttributes="Bold"
                       TextColor="#1D1D1F" Margin="4,8,0,4" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Frame Grid.Column="0" BackgroundColor="White" CornerRadius="16"
                           HasShadow="False" Padding="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="🚗" FontSize="24" HorizontalOptions="Center" />
                            <Label Text="Автомобілів" FontSize="12" TextColor="#6E6E73"
                                   HorizontalOptions="Center" />
                            <Label x:Name="TotalVehiclesLabel" Text="0" FontSize="24"
                                   FontAttributes="Bold" TextColor="#0071E3"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="16"
                           HasShadow="False" Padding="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="🗺️" FontSize="24" HorizontalOptions="Center" />
                            <Label Text="Поїздок за тиждень" FontSize="12" TextColor="#6E6E73"
                                   HorizontalOptions="Center" />
                            <Label x:Name="WeekTripsLabel" Text="0" FontSize="24"
                                   FontAttributes="Bold" TextColor="#34C759"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Frame BackgroundColor="White" CornerRadius="16" HasShadow="False" Padding="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="💰 Загальні витрати" FontSize="15"
                                   FontAttributes="Bold" TextColor="#1D1D1F" />
                            <Label Text="За всіма автомобілями" FontSize="12" TextColor="#6E6E73" />
                        </VerticalStackLayout>
                        <Label x:Name="TotalExpensesLabel" Grid.Column="1" Text="0.00 грн"
                               FontSize="18" FontAttributes="Bold" TextColor="#FF3B30"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <Label Text="По автомобілях" FontSize="17" FontAttributes="Bold"
                       TextColor="#1D1D1F" Margin="4,4,0,4" />

                <CollectionView x:Name="VehicleReportCollection">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="White" CornerRadius="14" Margin="0,4"
                                   HasShadow="False" Padding="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="{Binding Brand, StringFormat='{0} '}" FontSize="15"
                                               FontAttributes="Bold" TextColor="#1D1D1F" />
                                        <Label Text="{Binding PlateNumber}" FontSize="13" TextColor="#6E6E73" />
                                        <Label Text="{Binding CurrentMileage, StringFormat='Пробіг: {0:N0} км'}"
                                               FontSize="12" TextColor="#0071E3" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                                        <Label Text="{Binding TripLogs.Count, StringFormat='Поїздок: {0}'}"
                                               FontSize="12" TextColor="#6E6E73" HorizontalOptions="End" />
                                        <Label Text="{Binding Expenses.Count, StringFormat='Витрат: {0}'}"
                                               FontSize="12" TextColor="#6E6E73" HorizontalOptions="End" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Frame BackgroundColor="White" CornerRadius="16" HasShadow="False" Padding="16" Margin="0,4,0,0">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📋 Повний звіт" FontSize="15" FontAttributes="Bold" TextColor="#1D1D1F" />
                        <Label x:Name="FullReportLabel" Text="" FontSize="13" TextColor="#3C3C43"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Оновити звіт" BackgroundColor="#0071E3" TextColor="White"
                        FontAttributes="Bold" FontSize="15" CornerRadius="12"
                        HeightRequest="48" Margin="0,8,0,24" Clicked="OnRefreshClicked" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
