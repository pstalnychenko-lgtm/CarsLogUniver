<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.NotesPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*">
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="15,25,15,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Нотатки" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center" />
                <Button Grid.Column="2" Text="+" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="26" WidthRequest="44" Clicked="OnAddClicked" />
            </Grid>
        </Frame>

        <CollectionView Grid.Row="1" x:Name="NotesCollection"
                        EmptyView="Нотаток немає. Додайте першу нотатку."
                        Margin="16,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White" CornerRadius="14" Margin="0,4"
                           HasShadow="False" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding TitleNote}" FontSize="15"
                                       FontAttributes="Bold" TextColor="#1D1D1F" />
                                <Label Text="{Binding NoteContent}" FontSize="13" TextColor="#3C3C43"
                                       MaxLines="2" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding Category}" FontSize="12" TextColor="#6E6E73" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1"
                                   Text="{Binding CreatedAt, StringFormat='{0:dd.MM}'}"
                                   FontSize="12" TextColor="#C7C7CC" VerticalOptions="Start" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
