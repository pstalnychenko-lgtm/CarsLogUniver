<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*">

        <Border Grid.Row="0" BackgroundColor="White" StrokeThickness="0" Padding="15,25,15,15">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Профіль" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center" Margin="-44,0,0,0" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="20">

                <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="FullNameLabel" FontSize="24" FontAttributes="Bold" TextColor="#1D1D1F" HorizontalOptions="Center" />
                        <Label x:Name="RoleLabel" FontSize="16" TextColor="#0071E3" HorizontalOptions="Center" />
                        
                        <BoxView HeightRequest="1" Color="#E5E5E5" Margin="0,10" />
                        
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="15">
                            <Label Grid.Row="0" Grid.Column="0" Text="Email:" TextColor="#8E8E93" />
                            <Label Grid.Row="0" Grid.Column="1" x:Name="EmailLabel" TextColor="#1D1D1F" />
                            
                            <Label Grid.Row="1" Grid.Column="0" Text="Тел:" TextColor="#8E8E93" />
                            <Label Grid.Row="1" Grid.Column="1" x:Name="PhoneLabel" TextColor="#1D1D1F" />
                            
                            <Label Grid.Row="2" Grid.Column="0" Text="Реєстрація:" TextColor="#8E8E93" />
                            <Label Grid.Row="2" Grid.Column="1" x:Name="RegDateLabel" TextColor="#1D1D1F" />
                            
                            <Label Grid.Row="3" Grid.Column="0" Text="Статус:" TextColor="#8E8E93" />
                            <Label Grid.Row="3" Grid.Column="1" x:Name="StatusLabel" TextColor="#1D1D1F" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="OwnerInfoFrame" IsVisible="False" BackgroundColor="White" StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Інформація власника" FontAttributes="Bold" FontSize="18" />
                        <Label Text="Адреса:" TextColor="#8E8E93" />
                        <Label x:Name="AddressLabel" />
                        <Label Text="Кількість авто:" TextColor="#8E8E93" />
                        <Label x:Name="VehicleCountLabel" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="DriverInfoFrame" IsVisible="False" BackgroundColor="White" StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Інформація водія" FontAttributes="Bold" FontSize="18" />
                        <Label Text="Посвідчення:" TextColor="#8E8E93" />
                        <Label x:Name="LicenseLabel" />
                        <Label Text="Дійсне до:" TextColor="#8E8E93" />
                        <Label x:Name="LicenseExpiryLabel" />
                        <Label Text="Група крові:" TextColor="#8E8E93" />
                        <Label x:Name="BloodTypeLabel" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FDF2F2" StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Історія переходів (останні 3)" FontAttributes="Bold" TextColor="#1D1D1F" />
                        <Label x:Name="HistoryLabel" FontSize="12" TextColor="#6E6E73" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="Вийти" Clicked="OnLogoutClicked" BackgroundColor="#FF3B30" TextColor="White" 
                        CornerRadius="12" HeightRequest="50" FontAttributes="Bold" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
