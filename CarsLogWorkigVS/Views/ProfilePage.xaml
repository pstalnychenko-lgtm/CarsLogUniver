<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*">
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="15,25,15,15">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Профіль" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center"
                       Margin="-44,0,0,0" />
            </Grid>
        </Frame>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="16">

                <Frame BackgroundColor="White" CornerRadius="16" HasShadow="False"
                       Padding="20" Margin="0,12,0,12">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Frame BackgroundColor="#EBF4FF" CornerRadius="36" WidthRequest="72"
                               HeightRequest="72" Padding="0" HasShadow="False"
                               HorizontalOptions="Center">
                            <Label Text="👤" FontSize="36" HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <Label x:Name="FullNameLabel" Text="—" FontSize="20"
                               FontAttributes="Bold" TextColor="#1D1D1F" HorizontalOptions="Center" />
                        <Frame BackgroundColor="#EBF4FF" CornerRadius="10" Padding="10,4"
                               HasShadow="False" HorizontalOptions="Center">
                            <Label x:Name="RoleLabel" Text="—" FontSize="13"
                                   TextColor="#0071E3" FontAttributes="Bold" />
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="White" CornerRadius="16" HasShadow="False" Padding="0" Margin="0,0,0,12">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Email" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                            <Label x:Name="EmailLabel" Grid.Column="1" Text="—" FontSize="15"
                                   TextColor="#6E6E73" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F2F2F7" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Телефон" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                            <Label x:Name="PhoneLabel" Grid.Column="1" Text="—" FontSize="15"
                                   TextColor="#6E6E73" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F2F2F7" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Дата реєстрації" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                            <Label x:Name="RegDateLabel" Grid.Column="1" Text="—" FontSize="15"
                                   TextColor="#6E6E73" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F2F2F7" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Статус" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                            <Label x:Name="StatusLabel" Grid.Column="1" Text="—" FontSize="15"
                                   TextColor="#34C759" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame x:Name="OwnerInfoFrame" BackgroundColor="White" CornerRadius="16"
                       HasShadow="False" Padding="0" Margin="0,0,0,12" IsVisible="False">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Власник" FontSize="13" TextColor="#6E6E73"
                               Margin="16,14,16,6" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="#F2F2F7" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Адреса" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                            <Label x:Name="AddressLabel" Grid.Column="1" Text="—" FontSize="15"
                                   TextColor="#6E6E73" VerticalOptions="Center"
                                   MaxLines="1" LineBreakMode="TailTruncation" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F2F2F7" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Автомобілів" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                            <Label x:Name="VehicleCountLabel" Grid.Column="1" Text="0" FontSize="15"
                                   TextColor="#0071E3" FontAttributes="Bold" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame x:Name="DriverInfoFrame" BackgroundColor="White" CornerRadius="16"
                       HasShadow="False" Padding="0" Margin="0,0,0,12" IsVisible="False">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Водій" FontSize="13" TextColor="#6E6E73"
                               Margin="16,14,16,6" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="#F2F2F7" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Посвідчення" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                            <Label x:Name="LicenseLabel" Grid.Column="1" Text="—" FontSize="15"
                                   TextColor="#6E6E73" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F2F2F7" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Дійсне до" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                            <Label x:Name="LicenseExpiryLabel" Grid.Column="1" Text="—" FontSize="15"
                                   TextColor="#6E6E73" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F2F2F7" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Група крові" FontSize="15" TextColor="#1D1D1F" VerticalOptions="Center" />
                            <Label x:Name="BloodTypeLabel" Grid.Column="1" Text="—" FontSize="15"
                                   TextColor="#FF3B30" FontAttributes="Bold" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Вийти з акаунту" BackgroundColor="#FFF1F0" TextColor="#FF3B30"
                        FontAttributes="Bold" FontSize="15" CornerRadius="12"
                        HeightRequest="48" Margin="0,8,0,24" Clicked="OnLogoutClicked" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
