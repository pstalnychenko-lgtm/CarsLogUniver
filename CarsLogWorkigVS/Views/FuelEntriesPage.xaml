<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.FuelEntriesPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*">
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="15,25,15,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Заправки" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center" />
                <Button Grid.Column="2" Text="+" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="26" WidthRequest="44" Clicked="OnAddClicked" />
            </Grid>
        </Frame>

        <CollectionView Grid.Row="1" x:Name="FuelCollection"
                        EmptyView="Записів заправок немає. Додайте першу заправку."
                        Margin="16,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White" CornerRadius="14" Margin="0,4"
                           HasShadow="False" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding GasStationName}" FontSize="16"
                                       FontAttributes="Bold" TextColor="#1D1D1F" />
                                <Label Text="{Binding FuelType}" FontSize="13" TextColor="#6E6E73" />
                                <Label Text="{Binding Liters, StringFormat='{0} л'}" FontSize="13" TextColor="#3C3C43" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                                <Label Text="{Binding TotalCost, StringFormat='{0:N2} грн'}"
                                       FontSize="16" FontAttributes="Bold" TextColor="#0071E3"
                                       HorizontalOptions="End" />
                                <Label Text="{Binding PricePerLiter, StringFormat='{0:N2} грн/л'}"
                                       FontSize="12" TextColor="#6E6E73" HorizontalOptions="End" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
