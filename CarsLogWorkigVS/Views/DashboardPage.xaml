<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.DashboardPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*,Auto">

        <Frame Grid.Row="0" BackgroundColor="#0071E3" CornerRadius="0" HasShadow="True" Padding="16,30,16,16">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0">
                    <Label x:Name="GreetingLabel" Text="Вітаємо!" FontSize="20"
                           FontAttributes="Bold" TextColor="White" />
                    <Label x:Name="SubtitleLabel" Text="Ваші авто" FontSize="14" TextColor="#BFD9F7" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="👤" BackgroundColor="Transparent"
                        FontSize="22" TextColor="White" WidthRequest="44" Clicked="OnProfileClicked" />
            </Grid>
        </Frame>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="16">

                <Label Text="Швидкий доступ" FontSize="17" FontAttributes="Bold"
                       TextColor="#1D1D1F" Margin="4,8,0,4" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                    <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="White" CornerRadius="16" Padding="16" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnVehiclesClicked" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="🚗" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="Автомобілі" FontSize="14" FontAttributes="Bold"
                                   TextColor="#1D1D1F" HorizontalOptions="Center" />
                            <Label x:Name="VehicleCountLabel" Text="0" FontSize="22"
                                   FontAttributes="Bold" TextColor="#0071E3" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="White" CornerRadius="16" Padding="16" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnReportClicked" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="📊" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="Звіт" FontSize="14" FontAttributes="Bold"
                                   TextColor="#1D1D1F" HorizontalOptions="Center" />
                            <Label Text="Тижневий" FontSize="13" TextColor="#6E6E73" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="0" BackgroundColor="White" CornerRadius="16" Padding="16" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDriversClicked" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="👨‍✈️" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="Водії" FontSize="14" FontAttributes="Bold"
                                   TextColor="#1D1D1F" HorizontalOptions="Center" />
                            <Label Text="Керувати" FontSize="13" TextColor="#6E6E73" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="1" BackgroundColor="White" CornerRadius="16" Padding="16" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAdminClicked" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="⚙️" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="Адмін" FontSize="14" FontAttributes="Bold"
                                   TextColor="#1D1D1F" HorizontalOptions="Center" />
                            <Label Text="Панель" FontSize="13" TextColor="#6E6E73" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <Label Text="Останній автомобіль" FontSize="17" FontAttributes="Bold"
                       TextColor="#1D1D1F" Margin="4,8,0,4" />

                <Frame x:Name="LastVehicleFrame" BackgroundColor="White" CornerRadius="16"
                       HasShadow="False" Padding="16" IsVisible="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLastVehicleTapped" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label x:Name="LastVehicleName" Text="" FontSize="16"
                                   FontAttributes="Bold" TextColor="#1D1D1F" />
                            <Label x:Name="LastVehiclePlate" Text="" FontSize="14" TextColor="#6E6E73" />
                            <Label x:Name="LastVehicleMileage" Text="" FontSize="13" TextColor="#0071E3" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="›" FontSize="22" TextColor="#C7C7CC"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <Frame x:Name="EmptyVehicleFrame" BackgroundColor="White" CornerRadius="16"
                       HasShadow="False" Padding="16" IsVisible="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Немає автомобілів" FontSize="15" TextColor="#6E6E73"
                               HorizontalOptions="Center" />
                        <Button Text="+ Додати автомобіль" BackgroundColor="#0071E3" TextColor="White"
                                CornerRadius="10" HeightRequest="40" FontSize="14" Clicked="OnAddVehicleClicked" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <Frame Grid.Row="2" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="0,8">
            <Grid ColumnDefinitions="*,*,*,*" Padding="0">
                <VerticalStackLayout Grid.Column="0">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVehiclesClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="🚗" FontSize="22" HorizontalOptions="Center" />
                    <Label Text="Авто" FontSize="11" TextColor="#0071E3" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFuelClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="⛽" FontSize="22" HorizontalOptions="Center" />
                    <Label Text="Паливо" FontSize="11" TextColor="#6E6E73" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnExpensesClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="💰" FontSize="22" HorizontalOptions="Center" />
                    <Label Text="Витрати" FontSize="11" TextColor="#6E6E73" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="👤" FontSize="22" HorizontalOptions="Center" />
                    <Label Text="Профіль" FontSize="11" TextColor="#6E6E73" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Frame>

    </Grid>
</ContentPage>
