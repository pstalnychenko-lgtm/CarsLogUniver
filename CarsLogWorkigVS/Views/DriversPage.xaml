<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.DriversPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*">
        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="15,25,15,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Водії" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center" />
                <Button Grid.Column="2" Text="+" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="26" WidthRequest="44" Clicked="OnAddClicked" />
            </Grid>
        </Frame>

        <CollectionView Grid.Row="1" x:Name="DriversCollection"
                        EmptyView="Водіїв не знайдено. Додайте першого водія."
                        Margin="16,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White" CornerRadius="14" Margin="0,4"
                           HasShadow="False" Padding="16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Frame Grid.Column="0" BackgroundColor="#EBF4FF" CornerRadius="22"
                                   WidthRequest="44" HeightRequest="44" Padding="0" HasShadow="False"
                                   VerticalOptions="Center">
                                <Label Text="👨‍✈️" FontSize="22" HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                                <Label Text="{Binding FullName}" FontSize="16"
                                       FontAttributes="Bold" TextColor="#1D1D1F" />
                                <Label Text="{Binding LicenseNumber, StringFormat='Посвідчення: {0}'}"
                                       FontSize="13" TextColor="#6E6E73" />
                                <Label Text="{Binding DateOfLicenseFormatted, StringFormat='Дійсне до: {0}'}"
                                       FontSize="12" TextColor="#6E6E73" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22" TextColor="#C7C7CC"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
