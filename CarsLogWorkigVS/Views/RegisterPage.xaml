<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarsLogWorkigVS.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto,*">

        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="0" HasShadow="True" Padding="15,25,15,15">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="#0071E3"
                        FontSize="20" WidthRequest="44" Clicked="OnBackClicked" />
                <Label Grid.Column="1" Text="Реєстрація" FontSize="22" FontAttributes="Bold"
                       TextColor="#1D1D1F" VerticalOptions="Center" HorizontalOptions="Center" Margin="-44,0,0,0" />
            </Grid>
        </Frame>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="24">

                <Label Text="Ім'я" FontSize="13" TextColor="#6E6E73" Margin="4,16,0,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="FirstNameEntry" Placeholder="Ім'я" FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Прізвище" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="LastNameEntry" Placeholder="Прізвище" FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Логін" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="LoginEntry" Placeholder="Логін" FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Email" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="EmailEntry" Placeholder="example@email.com" Keyboard="Email"
                           FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Телефон" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="PhoneEntry" Placeholder="+380..." Keyboard="Telephone"
                           FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Пароль" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="PasswordEntry" Placeholder="Мін. 8 символів, велика літера, цифра"
                           IsPassword="True" FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Підтвердження паролю" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="16,4">
                    <Entry x:Name="ConfirmPasswordEntry" Placeholder="Повторіть пароль"
                           IsPassword="True" FontSize="16" TextColor="#1D1D1F" PlaceholderColor="#C7C7CC" />
                </Frame>

                <Label Text="Роль" FontSize="13" TextColor="#6E6E73" Margin="4,0" />
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="False" Padding="8,0">
                    <Picker x:Name="RolePicker" FontSize="16" TextColor="#1D1D1F">
                        <Picker.Items>
                            <x:String>Власник (Owner)</x:String>
                            <x:String>Водій (Driver)</x:String>
                        </Picker.Items>
                    </Picker>
                </Frame>

                <Label x:Name="ErrorLabel" TextColor="#FF3B30" FontSize="13"
                       HorizontalOptions="Center" IsVisible="False" Margin="0,4" />

                <Button Text="Зареєструватися" BackgroundColor="#0071E3" TextColor="White"
                        FontAttributes="Bold" FontSize="17" CornerRadius="12"
                        HeightRequest="52" Margin="0,8,0,24" Clicked="OnRegisterClicked" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
